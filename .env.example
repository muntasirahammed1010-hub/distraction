# =============================================================================
# .env.example — Anti-Distraction EdTech Ecosystem
# =============================================================================
# Copy this file to `.env.local` (web-app) and fill in real values.
# NEVER commit `.env.local` to source control.
# =============================================================================

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local dev: use a Docker container or Supabase free tier
DATABASE_URL="postgresql://postgres:password@localhost:5432/focusforge"

# ─── NEXTAUTH.JS ──────────────────────────────────────────────────────────────
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-32-char-string-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── GOOGLE OAUTH (for NextAuth Google provider) ─────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── GOOGLE GEMINI API ────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSy..."

# ─── APP URL (used by the Chrome Extension to know where to point) ───────────
# In production, this is your Vercel deployment URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
