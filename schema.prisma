// =============================================================================
// PRISMA SCHEMA — Anti-Distraction EdTech Ecosystem
// =============================================================================
// Run: npx prisma migrate dev --name init
//      npx prisma generate
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER ────────────────────────────────────────────────────────────────────
// Managed by NextAuth. The `accounts` / `sessions` / `verificationTokens`
// tables below are required by the Prisma NextAuth adapter.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // One-way hashed token used by the Chrome Extension to authenticate
  // API calls without requiring a full browser session cookie.
  // Generated on first dashboard visit; shown once in Settings.
  extensionToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  focusSessions FocusSession[]
  blockedSites  BlockedSite[]
  roastLogs     RoastLog[]
}

// ─── NEXTAUTH ADAPTER TABLES ─────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── FOCUS SESSION ───────────────────────────────────────────────────────────
// A single timed work session initiated from the dashboard.
// The Chrome Extension polls GET /api/session/status to check if
// the user currently has an active session before deciding to block.
model FocusSession {
  id        String    @id @default(cuid())
  userId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime? // null = still active

  // Optional: the planned duration in minutes (set by user on start)
  plannedDurationMin Int?

  // Number of block events that fired during this session
  blockedAttempts Int @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endedAt]) // Fast lookup for "does this user have an active session?"
}

// ─── BLOCKED SITE ─────────────────────────────────────────────────────────────
// The user's personal blocklist. The extension fetches this list on install
// and caches it with a 5-minute TTL using chrome.storage.local.
model BlockedSite {
  id      String @id @default(cuid())
  userId  String
  pattern String // e.g. "facebook.com", "*.twitter.com", "youtube.com/shorts"

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pattern]) // No duplicate patterns per user
}

// ─── ROAST LOG ────────────────────────────────────────────────────────────────
// Persists every roast generated by Gemini for analytics / history page.
model RoastLog {
  id        String @id @default(cuid())
  userId    String
  context   String // The trigger context sent to Gemini (e.g. "tried facebook.com")
  roastText String @db.Text // The generated roast

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
